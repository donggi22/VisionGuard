# 카메라 설정
CAMERA_INDEX=0
FPS=15
FRAME_WIDTH=640
FRAME_HEIGHT=480

# 모션 감지
MOTION_THRESHOLD=3000
MOTION_MIN_FRAMES=3
MOTION_ONLY_ALERT=true

# YOLO
YOLO_MODEL=yolov8n.pt
YOLO_CONFIDENCE=0.4

# 알림 대상 클래스 (COCO 클래스명, 쉼표 구분)
ALERT_CLASSES=person,car,cat,dog

# 녹화
PRE_RECORD_SECONDS=10
POST_RECORD_SECONDS=10

# Discord
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# 알림 쿨타임 (초)
ALERT_COOLDOWN_SECONDS=30

# 저장 보존 기간 (일)
RETENTION_DAYS=7

# 웹 서버
WEB_HOST=0.0.0.0
WEB_PORT=8080
